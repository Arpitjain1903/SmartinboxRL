# SmartInboxRL Environment Variables
# Copy this file to .env and fill in your values before running.

# ── MANDATORY (required by competition evaluator) ───────────────────────────

# The OpenAI-compatible API endpoint URL
# Examples:
#   https://api.groq.com/openai/v1
#   https://api.openai.com/v1
API_BASE_URL=https://api.groq.com/openai/v1

# The model identifier to use for inference
# Examples:
#   llama-3.1-8b-instant  (Groq)
#   gpt-4o-mini           (OpenAI)
MODEL_NAME=llama-3.1-8b-instant

# Your Hugging Face / API key (used by inference.py for authentication)
# This is the primary API key used by the OpenAI client in inference.py
HF_TOKEN=hf_your-api-key-here

# ── OPTIONAL / LEGACY ───────────────────────────────────────────────────────

# Legacy alias — inference.py will fall back to this if HF_TOKEN is not set
OPENAI_API_KEY=your-api-key-here

# Streamlit server port (default: 7860 for HF Spaces)
PORT=7860
